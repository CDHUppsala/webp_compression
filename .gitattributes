# Set default behavior to automatically normalize line endings.
* text=auto

# Force bash scripts to always use LF line endings so they work on Unix-like systems.
*.sh text eol=lf

# Python files
*.py text

# CSV files - often have mixed line endings if coming from Windows
*.csv text

# Binary files - use Git LFS for large image assets
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.tif filter=lfs diff=lfs merge=lfs -text
*.tiff filter=lfs diff=lfs merge=lfs -text
*.nef filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
